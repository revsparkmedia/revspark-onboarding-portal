NEXT_PUBLIC_TEST_MODE=true
NEXT_PUBLIC_TEST_TOKEN=same-value-as-TEST_BYPASS_TOKEN

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Base URL ───────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Stripe (LIVE — used when TEST_MODE is false) ──────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PER_LOCATION=price_...
STRIPE_PRICE_ID_BOOKING_ADDON=price_...

# ── Stripe (TEST — used when TEST_MODE is true) ──────────
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_TEST_WEBHOOK_SECRET=whsec_test_...
STRIPE_TEST_PRICE_ID_PER_LOCATION=price_test_...
STRIPE_TEST_PRICE_ID_BOOKING_ADDON=price_test_...

# ── BoldSign ──────────────────────────────────────────────
BOLDSIGN_API_KEY=...
